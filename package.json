{
  "name": "setup-inspequte",
  "description": "GitHub Actions to set up inspequte",
  "version": "0.0.0",
  "author": "",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "homepage": "https://github.com/KengoTODA/setup-inspequte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KengoTODA/setup-inspequte.git"
  },
  "bugs": {
    "url": "https://github.com/KengoTODA/setup-inspequte/issues"
  },
  "keywords": [
    "actions"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "pnpm run format:write && pnpm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "local-action": "local-action . src/main.ts .env",
    "package": "node -e \"require('node:fs').rmSync('./dist', { recursive: true, force: true })\" && rollup --config rollup.config.mjs",
    "package:watch": "pnpm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "all": "pnpm run format:write && pnpm run lint && pnpm run test && pnpm run coverage && pnpm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@github/local-action": "7.0.1",
    "@jest/globals": "30.4.1",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.3",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "make-coverage-badge": "1.2.0",
    "prettier": "3.8.4",
    "prettier-eslint": "16.4.2",
    "rollup": "4.61.1",
    "ts-jest": "29.4.11",
    "ts-jest-resolver": "2.0.1",
    "typescript": "6.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
